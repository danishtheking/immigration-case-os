# =============================================================================
# Immigration Case OS — environment variables
# Copy to .env and fill in real values for local dev. NEVER commit .env.
# Production secrets live in Doppler.
# =============================================================================

# --- Database (Postgres 16 + pgvector) ---
DATABASE_URL=postgres://app_admin:dev@localhost:5432/immcaseos
DATABASE_URL_TENANT=postgres://app_tenant:dev@localhost:5432/immcaseos
DATABASE_URL_ADMIN=postgres://app_admin:dev@localhost:5432/immcaseos

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME
CLERK_JWT_ISSUER=https://REPLACE.clerk.accounts.dev

# --- LLM (Anthropic primary, OpenAI fallback) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME

# --- Object storage (Cloudflare R2) ---
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET=immcaseos-dev

# --- KMS (per-tenant data keys) ---
# In dev we use a local libsodium key. In prod this points to AWS KMS.
KMS_PROVIDER=local
KMS_LOCAL_MASTER_KEY=local-dev-master-key-32-bytes-long-do-not-use-in-prod-please

# --- Workflow / event bus (Inngest) ---
INNGEST_EVENT_KEY=local-dev-key
INNGEST_SIGNING_KEY=signkey-local-dev
INNGEST_BASE_URL=http://localhost:8288

# --- Observability ---
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ML_URL=http://localhost:5000
ROOT_DOMAIN=localhost:3000

# --- Internal service auth ---
INTERNAL_SERVICE_SECRET=local-dev-internal-secret-change-me

# --- Node environment ---
NODE_ENV=development
LOG_LEVEL=debug
